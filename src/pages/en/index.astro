---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DestinationCard from '../../components/DestinationCard.astro';
import ProductCard from '../../components/ProductCard.astro';
import { useTranslations } from '../../i18n';
import { seoService, affiliateService } from '../../lib/services';
import { ACTIVE_DESTINATIONS } from '../../data/destinations';
import { FEATURED_CARTAGENA_IDS } from '../../data/featured';

const locale = 'en';
const t = useTranslations(locale);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';

const featuredLinks = affiliateService.getLinksForIds(FEATURED_CARTAGENA_IDS);

const seo = seoService.buildMetadata({
  title: t('seo.defaultTitle'),
  description: t('seo.defaultDescription'),
  canonical: `${siteUrl}/en/`,
  ogImage: siteUrl + '/images/og-default.jpg',
  ogImageAlt: 'Colombia Travel Hub',
  alternates: seoService.buildHreflang(siteUrl, '/', ['es', 'en']),
});
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  ogImage={seo.ogImage}
  ogImageAlt={seo.ogImageAlt}
  locale={locale}
  alternates={seo.alternates}
  currentPath="/en/"
>
  <!-- Hero -->
  <section class="relative bg-ink text-white overflow-hidden min-h-[540px] flex items-center">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/20 via-ink to-secondary/20"></div>
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-primary/10 blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="absolute -bottom-24 -left-24 w-96 h-96 rounded-full bg-secondary/10 blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-20 text-center">
      <p class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-sm font-semibold text-white/80 mb-6">
        <span aria-hidden="true">🇨🇴</span> Colombia Travel Hub
      </p>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6">
        {t('hero.title')}
      </h1>
      <p class="text-white/70 text-lg sm:text-xl max-w-2xl mx-auto mb-10">
        {t('hero.subtitle')}
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="#featured"
          class="inline-flex items-center gap-2 rounded-xl bg-secondary px-8 py-4 text-base font-bold text-white hover:brightness-110 active:translate-y-0.5 transition-all focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2"
        >
          {t('hero.cta')}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
        <a
          href="#destinations"
          class="inline-flex items-center gap-2 rounded-xl border-2 border-white/30 px-8 py-4 text-base font-bold text-white hover:bg-white/10 active:translate-y-0.5 transition-all"
        >
          {t('destinations.title')}
        </a>
      </div>
      <div class="mt-14 flex flex-wrap items-center justify-center gap-6 text-white/60 text-sm">
        <span class="flex items-center gap-1.5">
          <svg class="h-4 w-4 text-accent" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          {t('trust.secureBooking')}
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-4 w-4 text-accent" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
          </svg>
          {t('trust.freeCancellation')}
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="h-4 w-4 text-secondary" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          {t('trust.verifiedReviews')}
        </span>
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  {featuredLinks.length > 0 && (
    <section id="featured" class="bg-sand scroll-mt-20 py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-ink mb-3">
            {t('product.featured.title')}
          </h2>
          <p class="text-muted text-lg max-w-2xl mx-auto">
            {t('product.featured.subtitle')}
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredLinks.map((link) => (
            <ProductCard link={link} locale={locale} />
          ))}
        </div>
        <div class="mt-10 text-center">
          <a
            href="/en/cartagena/tours"
            class="inline-flex items-center gap-2 rounded-xl border-2 border-primary text-primary px-8 py-3 text-base font-bold hover:bg-primary hover:text-white transition-all duration-150"
          >
            {t('product.seeAll')}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Destinations -->
  <section id="destinations" class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 scroll-mt-20">
    <div class="text-center mb-12">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-ink mb-3">
        {t('destinations.title')}
      </h2>
      <p class="text-muted text-lg max-w-2xl mx-auto">
        {t('destinations.subtitle')}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {ACTIVE_DESTINATIONS.map((destination) => (
        <DestinationCard destination={destination} locale={locale} />
      ))}
    </div>
  </section>

  <!-- Provider logos strip -->
  <section class="bg-surface border-y border-ink/5 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-muted uppercase tracking-widest mb-8">
        Book with the world's best operators
      </p>
      <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-12">
        <span class="text-xl font-bold" style="color:#1DAD65">Viator</span>
        <span class="text-xl font-bold" style="color:#E50A17">Civitatis</span>
        <span class="text-xl font-bold" style="color:#FF6600">GetYourGuide</span>
      </div>
    </div>
  </section>
</BaseLayout>
