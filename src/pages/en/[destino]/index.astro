---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import CategoryNav from '../../../components/CategoryNav.astro';
import { useTranslations } from '../../../i18n';
import { contentService, seoService } from '../../../lib/services';
import { ACTIVE_DESTINATIONS } from '../../../data/destinations';
import type { DestinationSlug } from '../../../core/domain/models';

export async function getStaticPaths() {
  return ACTIVE_DESTINATIONS.map((d) => ({
    params: { destino: d.slug },
    props: { destination: d },
  }));
}

const { destination } = Astro.props;
const locale = 'en';
const t = useTranslations(locale);
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';

const articles = await contentService.getArticlesByDestination(
  destination.slug as DestinationSlug,
  locale,
);

const name = destination.names[locale] ?? destination.names['es'] ?? destination.slug;
const description = destination.descriptions[locale] ?? destination.descriptions['es'] ?? '';
const path = `/en/${destination.slug}`;
---

<BaseLayout
  title={`${name} — Colombia Travel Hub`}
  description={description}
  canonical={`${siteUrl}${path}`}
  ogImage={siteUrl + destination.image}
  ogImageAlt={destination.imageAlt}
  locale={locale}
  alternates={seoService.buildHreflang(siteUrl, `/${destination.slug}`, ['es', 'en'])}
  currentPath={path}
>
  <div class="relative h-56 sm:h-72 overflow-hidden">
    <img src={destination.image} alt={destination.imageAlt} width="1280" height="640" class="w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-t from-ink/70 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 p-6 sm:p-10">
      <h1 class="font-display text-3xl sm:text-5xl font-bold text-white">{name}</h1>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10">
    <p class="text-muted text-lg max-w-3xl mb-8">{description}</p>
    <CategoryNav locale={locale} destination={destination.slug as DestinationSlug} />
    <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {articles.length > 0
        ? articles.map((article) => <ArticleCard article={article} locale={locale} />)
        : <p class="text-muted col-span-full text-center py-12">{t('article.noArticles')}</p>
      }
    </div>
  </div>
</BaseLayout>
