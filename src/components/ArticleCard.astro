---
import type { Article, Locale } from '../core/domain/models';
import { useTranslations, getLocalizedPath } from '../i18n';
import { Image } from 'astro:assets';

interface Props {
  article: Article;
  locale: Locale;
}

const { article, locale } = Astro.props;
const t = useTranslations(locale);
const articlePath = getLocalizedPath(
  `/${article.destination}/${article.category}/${article.slug}`,
  locale,
);

const formattedDate = article.pubDate.toLocaleDateString(
  locale === 'en' ? 'en-US' : 'es-CO',
  { year: 'numeric', month: 'long', day: 'numeric' },
);
---

<article class="group flex flex-col rounded-2xl overflow-hidden bg-surface shadow-[0_4px_16px_rgba(249,115,22,0.08)] transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_12px_32px_rgba(14,165,233,0.15)]">
  <a href={articlePath} class="block overflow-hidden aspect-[16/9]">
    <img
      src={article.image}
      alt={article.imageAlt}
      width="640"
      height="360"
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
    />
  </a>

  <div class="flex flex-col flex-1 p-5 gap-3">
    <div class="flex items-center gap-2 text-xs text-muted uppercase tracking-wider">
      <span>{t(`category.${article.category}`)}</span>
      <span aria-hidden="true">·</span>
      <time datetime={article.pubDate.toISOString()}>{formattedDate}</time>
    </div>

    <h3 class="font-display text-lg font-bold text-ink leading-snug">
      <a href={articlePath} class="hover:text-primary transition-colors">
        {article.title}
      </a>
    </h3>

    <p class="text-muted text-sm leading-relaxed line-clamp-3 flex-1">
      {article.description}
    </p>

    <a
      href={articlePath}
      class="mt-auto inline-flex items-center gap-1 text-sm font-bold text-primary hover:text-secondary transition-colors"
    >
      {t('article.readMore')}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
