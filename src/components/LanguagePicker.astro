---
import type { Locale } from '../core/domain/models';
import { LOCALES, DEFAULT_LOCALE } from '../i18n/locales';
import { useTranslations, getLocalizedPath } from '../i18n';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const t = useTranslations(locale);

/** Strip existing locale prefix from currentPath to get the base path */
function getBasePath(path: string): string {
  for (const loc of LOCALES) {
    if (loc !== DEFAULT_LOCALE && path.startsWith(`/${loc}`)) {
      return path.slice(`/${loc}`.length) || '/';
    }
  }
  return path;
}

const basePath = getBasePath(currentPath);

const LANG_META: Record<string, { flag: string; label: string }> = {
  es: { flag: '🇨🇴', label: 'Español' },
  en: { flag: '🇺🇸', label: 'English' },
  pt: { flag: '🇧🇷', label: 'Português' },
};

const currentMeta = LANG_META[locale] ?? LANG_META['es'];
---

<div class="relative" id="lang-picker">
  <!-- Trigger button -->
  <button
    type="button"
    id="lang-trigger"
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-label={t('lang.switchTo')}
    class="flex items-center gap-1.5 rounded-lg px-2.5 py-1.5 text-sm font-semibold text-muted hover:text-ink hover:bg-ink/5 transition-colors focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-1"
  >
    <span aria-hidden="true">{currentMeta.flag}</span>
    <span class="hidden sm:inline uppercase text-xs tracking-wider font-bold">{locale}</span>
    <svg
      id="lang-chevron"
      xmlns="http://www.w3.org/2000/svg"
      class="h-3.5 w-3.5 transition-transform duration-150"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2.5"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <!-- Dropdown -->
  <ul
    id="lang-dropdown"
    role="listbox"
    aria-label={t('lang.switchTo')}
    class="absolute right-0 top-full mt-1.5 w-44 rounded-xl bg-surface border border-ink/10 shadow-[0_8px_32px_rgba(30,41,59,0.12)] overflow-hidden hidden z-50"
  >
    {LOCALES.map((loc) => {
      const meta = LANG_META[loc] ?? { flag: '🌐', label: loc };
      const href = getLocalizedPath(basePath, loc);
      const isActive = loc === locale;
      return (
        <li role="option" aria-selected={isActive}>
          <a
            href={href}
            hreflang={loc}
            class={[
              'flex items-center gap-3 px-4 py-2.5 text-sm transition-colors',
              isActive
                ? 'bg-primary/8 text-primary font-bold'
                : 'text-ink hover:bg-sand font-medium',
            ].join(' ')}
          >
            <span class="text-base" aria-hidden="true">{meta.flag}</span>
            <span>{meta.label}</span>
            {isActive && (
              <svg class="ml-auto h-4 w-4 text-primary shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            )}
          </a>
        </li>
      );
    })}

    <!-- Portuguese — coming soon -->
    <li role="option" aria-selected="false" aria-disabled="true">
      <span class="flex items-center gap-3 px-4 py-2.5 text-sm text-muted cursor-not-allowed opacity-60">
        <span class="text-base" aria-hidden="true">🇧🇷</span>
        <span>Português</span>
        <span class="ml-auto text-[10px] font-bold uppercase tracking-wide bg-ink/8 text-muted rounded-full px-1.5 py-0.5">
          {t('lang.soon')}
        </span>
      </span>
    </li>
  </ul>
</div>

<script>
  const picker = document.getElementById('lang-picker');
  const trigger = document.getElementById('lang-trigger');
  const dropdown = document.getElementById('lang-dropdown');
  const chevron = document.getElementById('lang-chevron');

  function open() {
    dropdown?.classList.remove('hidden');
    trigger?.setAttribute('aria-expanded', 'true');
    chevron?.classList.add('rotate-180');
  }

  function close() {
    dropdown?.classList.add('hidden');
    trigger?.setAttribute('aria-expanded', 'false');
    chevron?.classList.remove('rotate-180');
  }

  trigger?.addEventListener('click', () => {
    const isOpen = trigger.getAttribute('aria-expanded') === 'true';
    isOpen ? close() : open();
  });

  // Close when clicking outside
  document.addEventListener('click', (e) => {
    if (picker && !picker.contains(e.target as Node)) close();
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') close();
  });
</script>
