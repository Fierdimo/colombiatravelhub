---
import type { Destination, Locale } from '../core/domain/models';
import { useTranslations, getLocalizedPath } from '../i18n';

interface Props {
  destination: Destination;
  locale: Locale;
}

const { destination, locale } = Astro.props;
const t = useTranslations(locale);
const name = destination.names[locale] ?? destination.names['es'] ?? destination.slug;
const description = destination.descriptions[locale] ?? destination.descriptions['es'] ?? '';
const href = getLocalizedPath(`/${destination.slug}`, locale);
---

<article class="group relative flex flex-col rounded-2xl overflow-hidden shadow-[0_4px_16px_rgba(249,115,22,0.08)] transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_12px_32px_rgba(14,165,233,0.15)] min-h-[320px]">
  <!-- Background image -->
  <img
    src={destination.image}
    alt={destination.imageAlt}
    width="600"
    height="400"
    loading="lazy"
    decoding="async"
    class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
  />

  <!-- Gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/30 to-transparent"></div>

  <!-- Content -->
  <div class="relative mt-auto p-6 text-white">
    <h3 class="font-display text-2xl font-bold leading-tight mb-2">
      {name}
    </h3>
    <p class="text-white/80 text-sm leading-relaxed mb-4 line-clamp-2">
      {description}
    </p>
    <a
      href={href}
      class="inline-flex items-center gap-2 rounded-xl bg-secondary px-5 py-2.5 text-sm font-bold text-white transition-all duration-150 hover:brightness-110 active:translate-y-0.5 focus-visible:ring-2 focus-visible:ring-secondary focus-visible:ring-offset-2"
    >
      {t('destinations.explore')}
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
