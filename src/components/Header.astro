---
import type { Locale } from '../core/domain/models';
import { useTranslations, getLocalizedPath } from '../i18n';
import LanguagePicker from './LanguagePicker.astro';
import { CATEGORIES } from '../data/categories';

interface Props {
  locale: Locale;
  currentPath?: string;
}

const { locale, currentPath = '/' } = Astro.props;
const t = useTranslations(locale);
const homePath = getLocalizedPath('/', locale);
---

<header class="sticky top-0 z-50 w-full transition-all duration-300" id="main-header">
  <div class="bg-sand/90 backdrop-blur-md border-b border-ink/5 shadow-sm">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex h-16 items-center justify-between gap-4">

        <!-- Logo -->
        <a href={homePath} class="shrink-0 font-display text-xl font-bold text-ink hover:text-primary transition-colors">
          Colombia<span class="text-secondary">Travel</span>Hub
        </a>

        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
          {CATEGORIES.map((cat) => (
            <a
              href={getLocalizedPath('/cartagena/' + cat.slug, locale)}
              class="rounded-lg px-3 py-2 text-sm font-body font-semibold text-muted hover:text-ink hover:bg-ink/5 transition-colors"
            >
              {t(`category.${cat.slug}`)}
            </a>
          ))}
        </nav>

        <!-- Right side -->
        <div class="flex items-center gap-3">
          <LanguagePicker locale={locale} currentPath={currentPath} />

          <!-- Mobile hamburger -->
          <button
            id="mobile-menu-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="mobile-menu"
            aria-label={t('nav.menu')}
            class="md:hidden rounded-lg p-2 text-muted hover:text-ink hover:bg-ink/5 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>

      </div>
    </div>
  </div>

  <!-- Mobile menu drawer -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-surface border-b border-ink/10 shadow-lg"
    role="dialog"
    aria-label="Mobile navigation"
  >
    <nav class="mx-auto max-w-7xl px-4 py-4 flex flex-col gap-1">
      {CATEGORIES.map((cat) => (
        <a
          href={getLocalizedPath('/cartagena/' + cat.slug, locale)}
          class="flex items-center gap-3 rounded-xl px-4 py-3 text-base font-semibold text-ink hover:bg-sand transition-colors"
        >
          <span aria-hidden="true">{cat.icon}</span>
          {t(`category.${cat.slug}`)}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('hidden') === false;
    menu?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!toggle?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      menu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
