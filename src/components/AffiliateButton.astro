---
import type { AffiliateLink, Locale } from '../core/domain/models';
import { useTranslations } from '../i18n';
import { localizeAffiliateUrl } from '../lib/localizeAffiliateUrl';

interface Props {
  link: AffiliateLink;
  locale: Locale;
  variant?: 'primary' | 'secondary';
  class?: string;
}

const { link, locale, variant = 'primary', class: className = '' } = Astro.props;
const t = useTranslations(locale);
const bookingUrl = localizeAffiliateUrl(link.url, locale);

const baseClasses =
  'inline-flex items-center justify-center gap-2 rounded-xl px-6 py-3 font-body font-bold text-base transition-all duration-200 focus-visible:ring-2 focus-visible:ring-offset-2';

const variantClasses =
  variant === 'primary'
    ? 'bg-secondary text-white hover:brightness-110 active:translate-y-0.5 active:shadow-sm focus-visible:ring-secondary'
    : 'border-2 border-primary text-primary hover:bg-primary hover:text-white active:translate-y-0.5 focus-visible:ring-primary';

const providerLabel: Record<string, string> = {
  viator:       t('cta.bookOnViator'),
  civitatis:    t('cta.bookOnCivitatis'),
  getyourguide: t('cta.bookOnGetYourGuide'),
};

const label = providerLabel[link.provider] ?? t('article.bookNow');
---

<a
  href={bookingUrl}
  target="_blank"
  rel="noopener noreferrer sponsored"
  class={`${baseClasses} ${variantClasses} ${className}`}
  aria-label={`${label} — ${link.label}`}
>
  {link.priceFrom && (
    <span class="text-sm font-normal opacity-90">
      {t('article.priceFrom')} ${link.priceFrom}
    </span>
  )}
  <span>{label}</span>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="h-4 w-4 shrink-0"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
    aria-hidden="true"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
  </svg>
</a>
