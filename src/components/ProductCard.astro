---
import type { AffiliateLink, Locale } from '../core/domain/models';
import { useTranslations } from '../i18n';
import { localizeAffiliateUrl } from '../lib/localizeAffiliateUrl';

interface Props {
  link: AffiliateLink;
  locale: Locale;
}

const { link, locale } = Astro.props;
const t = useTranslations(locale);
const bookingUrl = localizeAffiliateUrl(link.url, locale);

const providerMeta: Record<string, { name: string; color: string; textColor: string }> = {
  viator:       { name: 'Viator',         color: '#1DAD65', textColor: 'white' },
  civitatis:    { name: 'Civitatis',      color: '#E50A17', textColor: 'white' },
  getyourguide: { name: 'GetYourGuide',   color: '#FF6600', textColor: 'white' },
};

const provider = providerMeta[link.provider] ?? { name: link.provider, color: '#64748B', textColor: 'white' };

const badgeLabel: Record<string, string> = {
  popular:    t('product.badge.popular'),
  bestPrice:  t('product.badge.bestPrice'),
  new:        t('product.badge.new'),
};

const ratingStars = link.rating
  ? Math.round(link.rating * 2) / 2  // round to nearest 0.5
  : null;

const formattedReviews = link.reviewCount
  ? link.reviewCount >= 1000
    ? `${(link.reviewCount / 1000).toFixed(1)}k`
    : String(link.reviewCount)
  : null;
---

<article class="group flex flex-col rounded-2xl overflow-hidden bg-surface shadow-[0_4px_20px_rgba(30,41,59,0.08)] transition-all duration-200 hover:-translate-y-1.5 hover:shadow-[0_16px_40px_rgba(14,165,233,0.15)]">

  <!-- Image -->
  <div class="relative overflow-hidden aspect-[4/3]">
    {link.imageUrl ? (
      <img
        src={link.imageUrl}
        alt={link.label}
        width="640"
        height="480"
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        onerror="this.src='/images/placeholder-tour.svg'"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-primary/20 to-secondary/20 flex items-center justify-center">
        <span class="text-5xl" aria-hidden="true">ðŸï¸</span>
      </div>
    )}

    <!-- Provider badge (top left) -->
    <span
      class="absolute top-3 left-3 rounded-full px-2.5 py-1 text-[11px] font-bold tracking-wide uppercase"
      style={`background:${provider.color};color:${provider.textColor}`}
    >
      {provider.name}
    </span>

    <!-- Highlight badge (top right) -->
    {link.badge && (
      <span class="absolute top-3 right-3 rounded-full bg-secondary text-white px-2.5 py-1 text-[11px] font-bold tracking-wide uppercase">
        {badgeLabel[link.badge] ?? link.badge}
      </span>
    )}
  </div>

  <!-- Body -->
  <div class="flex flex-col flex-1 p-5 gap-3">

    <!-- Rating row -->
    {ratingStars && (
      <div class="flex items-center gap-1.5">
        <div class="flex text-secondary" aria-hidden="true">
          {Array.from({ length: 5 }).map((_, i) => {
            const full = i < Math.floor(ratingStars);
            const half = !full && i < ratingStars;
            return (
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                {full ? (
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                ) : half ? (
                  <>
                    <defs>
                      <linearGradient id={`half-${link.id}-${i}`}>
                        <stop offset="50%" stop-color="currentColor" />
                        <stop offset="50%" stop-color="#E2E8F0" />
                      </linearGradient>
                    </defs>
                    <path fill={`url(#half-${link.id}-${i})`} d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </>
                ) : (
                  <path fill="#E2E8F0" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                )}
              </svg>
            );
          })}
        </div>
        <span class="text-sm font-bold text-ink">{link.rating}</span>
        {formattedReviews && (
          <span class="text-xs text-muted">({formattedReviews} {t('article.reviews')})</span>
        )}
      </div>
    )}

    <!-- Title -->
    <h3 class="font-display text-lg font-bold text-ink leading-snug">
      {link.label}
    </h3>

    <!-- Description -->
    {link.description && (
      <p class="text-muted text-sm leading-relaxed line-clamp-2">{link.description}</p>
    )}

    <!-- Duration + Price row -->
    <div class="flex items-center justify-between mt-auto pt-3 border-t border-ink/5">
      {link.duration && (
        <div class="flex items-center gap-1 text-sm text-muted">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>{link.duration}</span>
        </div>
      )}
      {link.priceFrom && (
        <div class="text-right">
          <span class="text-xs text-muted">{t('article.priceFrom')}</span>
          <span class="ml-1 text-lg font-bold text-ink">
            {link.currency === 'USD' ? '$' : ''}{link.priceFrom}
          </span>
          <span class="text-xs text-muted ml-0.5">{link.currency ?? 'USD'}</span>
        </div>
      )}
    </div>

    <!-- CTA button -->
    <a
      href={bookingUrl}
      target="_blank"
      rel="noopener noreferrer sponsored"
      class="mt-1 w-full inline-flex items-center justify-center gap-2 rounded-xl bg-primary px-5 py-3 text-sm font-bold text-white transition-all duration-150 hover:brightness-110 active:translate-y-0.5 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
      aria-label={`${t('article.bookNow')}: ${link.label}`}
    >
      {t('article.bookNow')}
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
      </svg>
    </a>

  </div>
</article>

