# Colombia Travel Hub — Variables de entorno
# Copia este archivo como .env (gitignored) y completa los valores.
# En Vercel: Settings → Environment Variables

# ─── Viator ───────────────────────────────────────────────────────────────────
# API Key del programa de afiliados (server-side, para fetch en build time)
# Regístrate en: https://www.viator.com/partner
# Una vez aceptado, la API key aparece en tu dashboard de partner.
VIATOR_API_KEY=

# Tu Partner ID de Viator, se embebe en las URLs de afiliado (?pid=...)
# Lo encuentras en tu dashboard de Viator partner como "PID"
VIATOR_PARTNER_ID=

# ─── GetYourGuide ──────────────────────────────────────────────────────────────
# Partner ID de GYG (sirve tanto para la API como para las URLs de afiliado)
# Regístrate en: https://affiliate.getyourguide.com
# Lo encuentras en tu perfil de afiliado como "Partner ID"
GYG_PARTNER_ID=

# ─── Civitatis ────────────────────────────────────────────────────────────────
# AID (Affiliate ID) de Civitatis, se embebe en las URLs (?aid=...)
# Regístrate en: https://www.civitatis.com/es/afiliados/
CIVITATIS_AID=
